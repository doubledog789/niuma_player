diff --git a/ijkmedia/ijkplayer/android/ijkplayer_jni.c b/ijkmedia/ijkplayer/android/ijkplayer_jni.c
index 40c19d8..f42f4d5 100755
--- a/ijkmedia/ijkplayer/android/ijkplayer_jni.c
+++ b/ijkmedia/ijkplayer/android/ijkplayer_jni.c
@@ -1234,6 +1234,15 @@ JNIEXPORT jint JNI_OnLoad(JavaVM *vm, void *reserved)
     IJK_FIND_JAVA_CLASS(env, g_clazz.clazz, JNI_CLASS_IJKPLAYER);
     //MARK 注册IjkMediaPlayer的native方法
     (*env)->RegisterNatives(env, g_clazz.clazz, g_methods, NELEM(g_methods) );
+    //MARK 此 fork 把 ijksdl / ijkj4a 编成独立 .so，它们各自的 JNI_OnLoad 不会被
+    // Android runtime 调用（只有 System.loadLibrary 直接加载的库才触发，
+    // DT_NEEDED 被动带入的不触发）。原本由 ijksdl 的 JNI_OnLoad 完成的两件关键
+    // 初始化因此从未执行：① 给 ijksdl 注入 JavaVM（message-loop 线程 attach 用），
+    // ② J4A_LoadAll 加载全部 j4a 类的 field/method ID。缺 ① → 事件发不回 Java
+    // → prepared 超时；缺 ② → native_setup 读 mNativeMediaPlayer 得 NULL jfieldID
+    // → CheckJNI SIGABRT。在此由主 JNI_OnLoad 代为补齐。
+    SDL_JNI_SetJvm(vm);
+    J4A_LoadAll__catchAll(env);
     //MARK 注册ffmpeg 组件和网络 和 自定义模块
     ijkmp_global_init();
     //MARK 注册检测在线直播流回调
diff --git a/ijkmedia/ijksdl/android/ijksdl_android_jni.c b/ijkmedia/ijksdl/android/ijksdl_android_jni.c
index c5ac420..841bd35 100644
--- a/ijkmedia/ijksdl/android/ijksdl_android_jni.c
+++ b/ijkmedia/ijksdl/android/ijksdl_android_jni.c
@@ -40,6 +40,15 @@ JavaVM *SDL_JNI_GetJvm()
     return g_jvm;
 }
 
+// 此 fork 把 ijksdl 编成独立 .so，其 JNI_OnLoad 不会被 Android runtime 调用
+// （只有 System.loadLibrary 直接加载的库才触发），导致 g_jvm 始终为 NULL，
+// message-loop 线程 SDL_JNI_SetupThreadEnv 失败、事件发不回 Java。
+// 暴露 setter 让 libijkplayer.so 的主 JNI_OnLoad 代为注入 JavaVM。
+void SDL_JNI_SetJvm(JavaVM *vm)
+{
+    g_jvm = vm;
+}
+
 static void SDL_JNI_ThreadDestroyed(void* value)
 {
     JNIEnv *env = (JNIEnv*) value;
